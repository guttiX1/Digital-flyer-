# ── Required for testnet/mainnet deployment ───────────────────────────────────
# Your deployer wallet private key (no 0x prefix needed by some tools, but add it here)
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polygon Amoy RPC (free public endpoint or your Alchemy/Infura URL)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Polygon Mainnet RPC
POLYGON_RPC_URL=https://polygon-rpc.com

# ── Optional ──────────────────────────────────────────────────────────────────
# PolygonScan API key for contract verification
POLYGONSCAN_API_KEY=YOUR_POLYGONSCAN_API_KEY

# Set to address of existing USDC on the target network.
# Leave blank to deploy a MockUSDC (testnet / local only).
USDC_ADDRESS=

# Enable gas cost reporting in tests
REPORT_GAS=false
