# CarrerasOS MCP Server — Environment Variables

# Anthropic (design brief generation + listing copy)
ANTHROPIC_API_KEY=sk-ant-...

# Printify (POD fulfillment)
PRINTIFY_API_KEY=...
PRINTIFY_SHOP_ID=...

# Etsy (storefront)
ETSY_API_KEY=...
ETSY_SHOP_ID=...
ETSY_ACCESS_TOKEN=...

# Kittl (design generation — future)
KITTL_API_KEY=...

# Image generation (pick one)
REPLICATE_API_KEY=...      # FLUX via Replicate
# OPENAI_API_KEY=...       # DALL-E fallback

# Database path (defaults to ../carrerasos.db relative to mcp-server/)
DB_PATH=../carrerasos.db

# Designs output folder
DESIGNS_DIR=../output/designs
